{
  "dataset": "ionosphere",
  "n_splits": 10,
  "seed": 42,

  "_notes": {
    "n": 351, "d": 34, "classes": 2,
    "history": {
      "DKN-AGOP":      "D=1000, C=1.0 fixed. rank=200 dominant (5/10), rank=300 only 1/10 → [150,200,250]. n_layers=2 dominant (7/10) → [2,3].",
      "DKN-Align":     "lr=0.0001, C=1.0 fixed. n_layers spread → [2,3,4]. D split 6/4 → [500,1000]. Grid 3x2=6 candidates.",
      "DKN-RFM-Align": "D=1000, rank=34, agop_steps=3, lr=0.0001, C=1.0 all fixed. n_layers only open question → [1,2,3]. Grid 3 candidates.",
      "SVC-RBF":       "C=10.0 fixed.",
      "note":          "Final ionosphere run — dataset near-saturated at n=351."
    }
  },

  "models": {

    "ML-SVM": {
      "class": "mlsvm",
      "params": { "n_layers": 2, "n_components": 1000 }
    },

    "DKN-AGOP": {
      "class": "dkn_agop",
      "params": {
        "n_layers":   2,
        "D":          1000,
        "rank":       200,
        "C":          1.0,
        "agop_steps": 1
      },
      "param_grid": {
        "n_layers": [2, 3],
        "rank":     [150, 200, 250]
      },
      "tuning": { "inner_splits": 5, "strategy": "grid" }
    },

    "DKN-Align": {
      "class": "dkn_align",
      "params": {
        "n_layers":   3,
        "d_k":        200,
        "D":          500,
        "C":          1.0,
        "lr":         0.0001,
        "epochs":     300,
        "batch_size": 512
      },
      "param_grid": {
        "n_layers": [2, 3, 4],
        "D":        [500, 1000]
      },
      "tuning": { "inner_splits": 5, "strategy": "grid" }
    },

    "DKN-RFM-Align": {
      "class": "dkn_rfm_align",
      "params": {
        "n_layers":   2,
        "D":          1000,
        "rank":       34,
        "C":          1.0,
        "agop_steps": 3,
        "lr":         0.0001,
        "epochs":     300,
        "batch_size": 64
      },
      "param_grid": {
        "n_layers": [1, 2, 3]
      },
      "tuning": { "inner_splits": 5, "strategy": "grid" }
    },

    "SVC-RBF": {
      "class": "svc",
      "params": { "C": 10.0, "gamma": "scale" }
    },

    "MLP": {
      "class": "mlp",
      "params": {
        "hidden_layer_sizes": [256, 256], "alpha": 0.0001, "max_iter": 500
      }
    },

    "XGBoost": {
      "class": "xgboost",
      "params": { "n_estimators": 500, "learning_rate": 0.05 }
    }

  }
}
