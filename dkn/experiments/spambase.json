{
  "dataset": "spambase",
  "n_splits": 10,
  "seed": 42,

  "_notes": {
    "n": 4601, "d": 57, "classes": 2,
    "status": "DEFINITIVE — all hyperparameters fixed from 4 rounds of tuning. No grids.",
    "provenance": {
      "DKN-AGOP":      "rank=50 confirmed over 4 runs. C=1.0 (10/10). n_layers=1 (8/10). D=1000 (7/10). agop_steps=1.",
      "DKN-Align":     "lr=0.001 (10/10). n_layers=2 (6/10). D=500 (6/10). C=1.0 (plurality).",
      "DKN-RFM-Align": "rank=57=d (7/10), agop_steps=5 (10/10), D=500 (10/10), C=1.0 (10/10), n_layers=3 (6/10). Structurally ineffective — full-rank selection indicates no low-rank discriminative geometry.",
      "SVC-RBF":       "C=10.0 (8/10).",
      "conclusion":    "XGBoost and MLP dominate. DKN-Align competitive (3rd). DKN-AGOP and DKN-RFM-Align fail structurally on this dataset."
    }
  },

  "models": {

    "ML-SVM": {
      "class": "mlsvm",
      "params": { "n_layers": 2, "n_components": 1000 }
    },

    "DKN-AGOP": {
      "class": "dkn_agop",
      "params": {
        "n_layers":   1,
        "D":          1000,
        "rank":       50,
        "C":          1.0,
        "agop_steps": 1
      }
    },

    "DKN-Align": {
      "class": "dkn_align",
      "params": {
        "n_layers":   2,
        "d_k":        200,
        "D":          500,
        "C":          1.0,
        "lr":         0.001,
        "epochs":     300,
        "batch_size": 512
      }
    },

    "DKN-RFM-Align": {
      "class": "dkn_rfm_align",
      "params": {
        "n_layers":   3,
        "D":          500,
        "rank":       57,
        "C":          1.0,
        "agop_steps": 5,
        "lr":         0.0001,
        "epochs":     300,
        "batch_size": 256
      }
    },

    "SVC-RBF": {
      "class": "svc",
      "params": { "C": 10.0, "gamma": "scale" }
    },

    "MLP": {
      "class": "mlp",
      "params": {
        "hidden_layer_sizes": [256, 256], "alpha": 0.0001, "max_iter": 500
      }
    },

    "XGBoost": {
      "class": "xgboost",
      "params": { "n_estimators": 500, "learning_rate": 0.05 }
    }

  }
}
