{
  "dataset": "breast_cancer",
  "n_splits": 10,
  "seed": 42,

  "_notes": {
    "n": 699, "d": 30, "classes": 2,
    "history": "DKN-Align 0.974, ML-SVM 0.977, SVC-RBF 0.975 previously. DKN-Align lr=0.0001 selected all 10 folds — fix it in params to save tuning budget. rank was mixed (20-100). Key question: can deeper architectures close the gap with SVC-RBF?",
    "time_budget": "small-n dataset — 25 random candidates manageable"
  },

  "models": {

    "ML-SVM": {
      "class": "mlsvm",
      "params": { "n_layers": 2, "n_components": 1000 }
    },

    "DKN-AGOP": {
      "class": "dkn_agop",
      "params": {
        "n_layers": 2, "D": 500, "rank": 50,
        "C": 1.0, "agop_steps": 1
      },
      "param_grid": {
        "n_layers": [1, 2, 3, 4],
        "rank":     [20, 50, 100],
        "C":        [0.1, 1.0, 10.0],
        "D":        [500, 1000]
      },
      "tuning": { "inner_splits": 5, "strategy": "random", "n_iter": 25 }
    },

    "DKN-Align": {
      "class": "dkn_align",
      "params": {
        "n_layers": 2, "d_k": 200, "D": 500,
        "C": 1.0, "lr": 0.0001, "epochs": 300, "batch_size": 256
      },
      "_comment_lr": "lr=0.0001 was selected in all 10 folds previously — kept fixed in params, removed from grid to save budget. Only n_layers, C, D explored.",
      "param_grid": {
        "n_layers": [1, 2, 3, 4],
        "C":        [0.1, 1.0, 10.0],
        "D":        [500, 1000]
      },
      "tuning": { "inner_splits": 5, "strategy": "grid" }
    },

    "SVC-RBF": {
      "class": "svc",
      "params": { "C": 1.0, "gamma": "scale" },
      "param_grid": { "C": [0.1, 1.0, 10.0, 100.0] },
      "tuning": { "inner_splits": 5, "strategy": "grid" }
    },

    "MLP": {
      "class": "mlp",
      "params": {
        "hidden_layer_sizes": [256, 256], "alpha": 0.0001, "max_iter": 500
      }
    },

    "XGBoost": {
      "class": "xgboost",
      "params": { "n_estimators": 500, "learning_rate": 0.05 }
    }

  }
}
