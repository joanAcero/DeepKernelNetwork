{
  "dataset": "iris",
  "n_splits": 5,
  "seed": 42,

  "_comment": "Smoke test — validates DKN-RFM-Align runs without error. Uses 5 folds and small hyperparameters to finish in seconds. Not a benchmark — do not interpret results scientifically.",

  "models": {

    "DKN-RFM-Align": {
      "class": "dkn_rfm_align",
      "params": {
        "n_layers":   2,
        "D":          100,
        "rank":       20,
        "C":          1.0,
        "agop_steps": 3,
        "lr":         0.001,
        "epochs":     50,
        "batch_size": 64
      }
    },

    "SVC-RBF": {
      "class": "svc",
      "params": { "C": 1.0, "gamma": "scale" }
    }

  }
}
